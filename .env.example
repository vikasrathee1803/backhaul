# Backhaul — root environment template for apps/web (Next.js frontend + BFF)
# This is the canonical web env template; the same content lives at apps/web/.env.example.
# Copy to apps/web/.env.local and fill in. Never commit the filled file.
# NEXT_PUBLIC_* values are exposed to the browser by design; everything else is server-only.

# --- Database / Auth (Neon Postgres via Supabase JS client) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co   # Supabase/Neon project URL for the JS client (browser + server)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key                 # Public anon key for the browser Supabase client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key             # Service-role key (server only) — never import in a "use client" file

# --- Anthropic (BFF-only; never exposed to the browser) ---
ANTHROPIC_API_KEY=sk-ant-...                                # BFF-only Anthropic key for any server-side draft helper

# --- Stripe (test mode only) ---
STRIPE_SECRET_KEY=sk_test_...                               # Stripe test-mode secret key (server only)
STRIPE_PUBLISHABLE_KEY=pk_test_...                          # Stripe test-mode publishable key (browser)
STRIPE_WEBHOOK_SECRET=whsec_...                             # Verifies inbound Stripe webhook signatures (server only)

# --- Upstash Redis (live run state + checkpoints) ---
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io           # Upstash Redis REST endpoint (server only)
UPSTASH_REDIS_REST_TOKEN=your-upstash-token                 # Upstash Redis REST auth token (server only)

# --- Agent service (FastAPI) connection ---
AGENT_SERVICE_URL=http://localhost:8000                     # Internal URL of the Python FastAPI agent service (server only)
AGENT_SERVICE_SECRET=change-me-shared-secret                # Shared secret the BFF sends to authenticate to the agent service (server only)

# --- Analytics (optional) ---
NEXT_PUBLIC_POSTHOG_KEY=phc_...                             # Optional PostHog project key (browser)
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com           # Optional PostHog host (browser)

# --- Error monitoring (Sentry) ---
SENTRY_DSN=https://...@sentry.io/...                        # Sentry DSN for server-side error capture (server only)
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...            # Sentry DSN for browser error capture (browser)
