# Backhaul — apps/agent (Python FastAPI + LangGraph agent service) environment template
# Copy to apps/agent/.env and fill in. Never commit the filled file.
# All values are server-only. The agent service is never reachable directly by the browser.

DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require  # Neon Postgres connection string (direct SQL path)
ANTHROPIC_API_KEY=sk-ant-...                                # Anthropic key for all LLM nodes
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io           # Upstash Redis REST endpoint for live run state + LangGraph checkpoints
UPSTASH_REDIS_REST_TOKEN=your-upstash-token                 # Upstash Redis REST auth token
BRAINTRUST_API_KEY=your-braintrust-key                      # Braintrust API key for spans, traces, and eval logging
STRIPE_SECRET_KEY=sk_test_...                               # Stripe test-mode key for the Refund Worker
AGENT_SERVICE_SECRET=change-me-shared-secret                # Validates incoming BFF requests; reject any request missing/mismatching it
SENTRY_DSN=https://...@sentry.io/...                        # Sentry DSN for agent-service error capture
ENVIRONMENT=development                                     # development | production — toggles pacing delays, log verbosity, Sentry sampling
ALLOWED_ORIGINS=https://backhaul.vercel.app                 # comma-separated extra CORS origins beyond localhost:3000 (optional)
